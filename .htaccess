Options -Indexes
AcceptPathInfo On

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /php-form-builder/

    # Force Authorization header through to PHP (stripped by default on shared hosting)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Route all /api/* through the router
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^api/(.*)$ api/index.php/$1 [QSA,L]
</IfModule>

# Block access to sensitive files
<FilesMatch "\.(env|sql|md|lock|log)$">
    Order allow,deny
    Deny from all
</FilesMatch>
